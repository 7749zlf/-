# Backend production environment example.
# Set these values in the server environment before starting the jar.

SPRING_PROFILES_ACTIVE=prod
SHORT_VIDEO_PRODUCTION_MODE=true
SERVER_PORT=8081

SHORT_VIDEO_DB_URL=jdbc:mysql://127.0.0.1:3306/short_video?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=true
SHORT_VIDEO_DB_USERNAME=short_video
SHORT_VIDEO_DB_PASSWORD=replace-with-a-strong-database-password

SHORT_VIDEO_PUBLIC_BASE_URL=https://api.example.com
SHORT_VIDEO_CORS_ORIGINS=https://h5.example.com,https://admin.example.com
SHORT_VIDEO_AVATAR_UPLOAD_DIR=/data/short-video/uploads/avatars

# Used only when admin_users is empty. Change it before first production start.
SHORT_VIDEO_BOOTSTRAP_ADMIN_USERNAME=admin
SHORT_VIDEO_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
SHORT_VIDEO_BOOTSTRAP_ADMIN_NAME=Administrator

# Leave SHORT_VIDEO_ADMIN_TOKEN empty to disable the legacy admin token path.
SHORT_VIDEO_ADMIN_TOKEN=
SHORT_VIDEO_PAYMENT_CALLBACK_TOKEN=replace-with-a-long-random-callback-token
SHORT_VIDEO_DATA_ENCRYPTION_KEY=replace-with-at-least-32-chars-stable-data-key

SHORT_VIDEO_ADMIN_LOGIN_MAX_FAILURES=5
SHORT_VIDEO_ADMIN_LOGIN_LOCKOUT_MINUTES=10

# Disable local demo flows in production until real payment/order flows are connected.
SHORT_VIDEO_DEMO_INSTANT_UNLOCK_ENABLED=false
SHORT_VIDEO_DEMO_RECHARGE_ENABLED=false
SHORT_VIDEO_DEMO_PAYMENT_ENABLED=false
